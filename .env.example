# QuantumX Environment Variables Template
# Copy this file to .env and fill in your actual values
# ⚠️ NEVER commit .env files to the repository!

# Supabase Configuration
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Marketing API Key
# Generate a secure random key using: openssl rand -base64 32
# This key is used by Make.com to access the marketing-stats Edge Function
MARKETING_API_KEY="your-256-bit-random-key"

# Blockchain Explorers (Optional)
# Etherscan: https://etherscan.io/apis
VITE_ETHERSCAN_API_KEY="your-etherscan-api-key"

# Solscan: https://pro-api.solscan.io/
VITE_SOLSCAN_API_KEY="your-solscan-api-key"

# Anthropic Claude API (for Make.com Claude module)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Buffer (for social media posting)
# Get from: https://publish.buffer.com/developers
BUFFER_ACCESS_TOKEN="your-buffer-access-token"

# Perplexity API (Optional - for enhanced content generation)
# Get from: https://www.perplexity.ai/
PERPLEXITY_API_KEY="your-perplexity-api-key"

# PiAPI (Optional - for Flux image generation)
# Get from: https://piapi.ai/
PIAPI_KEY="your-piapi-key"

# OpenAI (Optional - for DALL-E image generation)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="your-openai-api-key"

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual API keys (never share these!)
# 3. The .env file is already gitignored - it will not be committed
# 4. For Supabase Edge Functions, set keys via: supabase secrets set KEY=value
# 5. For Make.com, store keys in scenario environment variables
